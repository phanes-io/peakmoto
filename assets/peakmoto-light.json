{
  "version": 8,
  "name": "PeakMoto Light",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sprite": "",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#F0F0F0"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#D4E4F1"
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#E0EAE0",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#E8F0E8",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#EAEAEA"
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#E0E0E0",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {
        "line-color": "#CCCCCC",
        "line-width": 1.5,
        "line-dasharray": [4, 2]
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#D4E4F1",
        "line-width": 1
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["in", "class", "path", "track"]],
      "minzoom": 13,
      "paint": {
        "line-color": "#D8D8D8",
        "line-width": 0.8,
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "road-service",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "service"]],
      "minzoom": 13,
      "paint": {
        "line-color": "#D8D8D8",
        "line-width": {"stops": [[13, 0.5], [16, 2]]}
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "minor"]],
      "minzoom": 11,
      "paint": {
        "line-color": "#CCCCCC",
        "line-width": {"stops": [[11, 0.5], [14, 2], [18, 5]]}
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "tertiary"]],
      "paint": {
        "line-color": "#AAAAAA",
        "line-width": {"stops": [[8, 0.5], [11, 1.5], [14, 4], [18, 8]]}
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "secondary"]],
      "paint": {
        "line-color": "#999999",
        "line-width": {"stops": [[7, 0.5], [10, 1.5], [14, 5], [18, 10]]}
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "primary"]],
      "paint": {
        "line-color": "#777777",
        "line-width": {"stops": [[6, 0.5], [9, 1.5], [14, 5], [18, 10]]}
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "trunk"]],
      "paint": {
        "line-color": "#BBBBBB",
        "line-width": {"stops": [[5, 0.5], [10, 2], [14, 5]]}
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["all", ["!has", "brunnel"], ["==", "class", "motorway"]],
      "paint": {
        "line-color": "#C8C8C8",
        "line-width": {"stops": [[5, 0.5], [10, 2], [14, 5]]}
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "rail"],
      "minzoom": 11,
      "paint": {
        "line-color": "#DDDDDD",
        "line-width": 1,
        "line-dasharray": [4, 4]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "minzoom": 12,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Open Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "minzoom": 11,
      "layout": {
        "text-field": "{name:de}",
        "text-font": ["Open Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#888888",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 8,
      "layout": {
        "text-field": "{name:de}",
        "text-font": ["Open Sans Regular"],
        "text-size": {"stops": [[8, 11], [12, 14]]}
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "minzoom": 5,
      "layout": {
        "text-field": "{name:de}",
        "text-font": ["Open Sans Regular"],
        "text-size": {"stops": [[5, 11], [10, 16], [14, 20]]}
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "minzoom": 3,
      "layout": {
        "text-field": "{name:de}",
        "text-font": ["Open Sans Regular"],
        "text-size": {"stops": [[3, 12], [6, 16]]},
        "text-transform": "uppercase",
        "text-letter-spacing": 0.15
      },
      "paint": {
        "text-color": "#999999",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 2
      }
    },
    {
      "id": "poi-mountain-peak",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "mountain_peak",
      "minzoom": 11,
      "layout": {
        "text-field": "{name:de}\n{ele}m",
        "text-font": ["Open Sans Regular"],
        "text-size": 10,
        "text-anchor": "top",
        "text-offset": [0, 0.3]
      },
      "paint": {
        "text-color": "#777777",
        "text-halo-color": "#F0F0F0",
        "text-halo-width": 1
      }
    }
  ]
}
